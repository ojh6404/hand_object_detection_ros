<launch>
  <arg name="input_image" default="/kinect_head/rgb/image_rect_color"/>
  <arg name="input_rects" default="/hand_object_detection_node/hands"/>
  <arg name="device" default="cuda:0" /> <!-- cpu or cuda -->
  <arg name="hand_threshold" default="0.9" />
  <arg name="object_threshold" default="0.9" />
  <arg name="min_detection_confidence" default="0.5" />
  <arg name="min_tracking_confidence" default="0.5" />
  <arg name="slop" default="0.1" />


  <!-- hand_object_detection node -->
  <node name="hand_object_detection_node"
        pkg="hand_object_detection_ros" type="hand_detection_node.py"
        output="screen" >
    <remap from="~input_image" to="$(arg input_image)" />
    <rosparam subst_value="true" >
        device: $(arg device)
        hand_threshold: $(arg hand_threshold)
        object_threshold: $(arg object_threshold)
    </rosparam>
  </node>
  <node name="hand_tracking_3d_node"
        pkg="hand_object_detection_ros" type="tracking_3d_node.py"
        output="screen" >
    <remap from="~input_image" to="$(arg input_image)" />
    <remap from="~input_rects" to="$(arg input_rects)" />
    <rosparam subst_value="true" >
        min_detection_confidence: $(arg min_detection_confidence)
        min_tracking_confidence: $(arg min_tracking_confidence)
        slop: $(arg slop)
    </rosparam>
  </node>
</launch>
